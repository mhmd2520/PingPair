{
  "network": {
    "server_ip": "192.168.1.1",
    "client_ip": "192.168.1.2",
    "subnet_mask": "255.255.255.0",
    "control_port": 5202,
    "iperf3_port": 5201
  },
  "test_plan": {
    "payloads_bytes": [
      200,
      600,
      1000,
      1300
    ],
    "bandwidths_mbps": [
      10,
      30,
      50,
      70,
      90
    ],
    "duration_s": 30,
    "interval_s": 1,
    "protocol": "udp"
  },
  "fping": {
    "interval_ms": 10,
    "extra_args": [
      "-l",
      "-s",
      "-D"
    ]
  },
  "report": {
    "default_dir": null,
    "filename_pattern": "PingTool_{date}_{time}",
    "formats": [
      "docx",
      "xlsx",
      "pdf",
      "txt"
    ],
    "open_after_save": true
  },
  "ui": {
    "theme": "dark",
    "live_chart": true
  }
}
